# Sierpinski Triangle in EGL - Depth 4

S(600, 600, "white");

:sier($x, $y, $sz, $dp) {
    ?($dp == 0) {
        $x2 = $x + $sz;
        $x3 = $x + $sz / 2;
        $y3 = $y - $sz * 0.866;
        F("blue");
        G($x, $y, $x2, $y, $x3, $y3);
    } : {
        $h = $sz / 2;
        $nd = $dp - 1;
        !sier($x, $y, $h, $nd);
        !sier($x + $h, $y, $h, $nd);
        !sier($x + $h / 2, $y - $h * 0.866, $h, $nd);
    }
}

!sier(50, 550, 500, 4);
