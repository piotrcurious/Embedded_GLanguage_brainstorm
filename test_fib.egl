# Refined Fibonacci for depth-based testing

:fib($n) {
    ?($n <= 1) {
        $result = $n;
    } : {
        $v1 = $n - 1;
        !fib($v1);
        $res1 = $result;
        $v2 = $n - 2;
        !fib($v2);
        $res2 = $result;
        $result = $res1 + $res2;
    }
}

$result = 0;
!fib(6);
>($result); # Should be 8
