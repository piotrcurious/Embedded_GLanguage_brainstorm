# Test Sprite Infrastructure in EGL

S(600, 600, "black");

# Define a sprite "ship" 40x40
P("ship", 40, 40);
[
    F("white");
    G(20, 5, 5, 35, 35, 35); # Triangle ship
    F("cyan");
    M(20, 25); C(5); # Cockpit
]

# Switch back to main screen (automatically happens when we pop state if we used [P...])
# But P manually sets active_surface. Let's just use S to reset if needed or pop state.
S(600, 600, "black");

# Draw some stars
@($i, 1, 50, 1) {
    $sx = (12345 * $i) % 600;
    $sy = (67890 * $i) % 600;
    K("white", 1);
    M($sx, $sy); L($sx + 1, $sy);
}

# Draw the sprite multiple times
@($j, 0, 360, 45) {
    $rad = $j * $pi / 180;
    $px = 300 + 200 * cos($rad) - 20;
    $py = 300 + 200 * sin($rad) - 20;
    D("ship", $px, $py);
}

# Also draw one in the center
D("ship", 280, 280);
