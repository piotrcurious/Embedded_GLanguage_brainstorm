# EGL Collision Logic Test
# HC(x1, y1, w1, h1, x2, y2, w2, h2) -> $result

S(400, 300, "white");

# Test 1: Colliding
HC(10, 10, 50, 50, 40, 40, 50, 50);
$c1 = $result;
> ("Colliding: " + $c1); # Should be 1

# Test 2: Not Colliding
HC(10, 10, 50, 50, 100, 100, 50, 50);
$c2 = $result;
> ("Not Colliding: " + $c2); # Should be 0

# Visuals
F("gray"); BX(10, 10, 50, 50);
?( $c1 == 1 ) { F("red"); } : { F("green"); }
BX(40, 40, 50, 50);

FB();
